# ============================================
# AAU Student Council Backend - Environment Variables
# ============================================

# Server Configuration
PORT=3001
NODE_ENV=development

# Frontend URL (for CORS configuration)
FRONTEND_URL=http://localhost:5173

# ============================================
# Supabase Configuration
# ============================================

# Supabase Project URL
# Get this from your Supabase project dashboard -> Settings -> API
SUPABASE_URL=your-supabase-project-url

# Supabase Anon Key (Public Key)
# Get this from your Supabase project dashboard -> Settings -> API
# This key is safe to use on the client side
SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase Service Role Key (Secret Key)
# Get this from your Supabase project dashboard -> Settings -> API
# WARNING: This key bypasses RLS policies - keep it secret and never expose it on the client side
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
